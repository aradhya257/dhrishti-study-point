# Copy this file to .env for local development and fill in real values.
# NEVER commit the actual .env file to GitHub.

# Flask
SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=1
PORT=5000

# Database (MySQL)
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/dhrishti_study_point

# Study space configuration
TOTAL_SEATS=40

# Initial admin account (used only once by seed.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisPassword123

# Contact info shown on the website
STUDY_POINT_PHONE=+91-8931848212
STUDY_POINT_EMAIL=info@dhrishtistudypoint.com

# Google Maps embed URL (Google Maps > Share > Embed a map > copy the src URL)
GOOGLE_MAP_EMBED_URL=https://www.google.com/maps?q=Mata+Mai+Mandir+Salarpur+Varanasi&output=embed
